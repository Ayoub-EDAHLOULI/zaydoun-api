<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New support message — Zaydoun</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap");

      body {
        margin: 0;
        padding: 0;
        background-color: #0a0a0a;
        color: #e8e0d0;
        font-family: "Inter", "Segoe UI", sans-serif;
        font-weight: 400;
        -webkit-font-smoothing: antialiased;
      }

      .wrapper {
        padding: 40px 20px;
        background-color: #0a0a0a;
      }

      .container {
        max-width: 560px;
        margin: 0 auto;
        background-color: #111111;
        border: 1px solid #2a2a2a;
        overflow: hidden;
      }

      /* ── Header ── */
      .header {
        background-color: #0d0d0d;
        padding: 40px 40px 32px;
        text-align: center;
        border-bottom: 1px solid #1e1e1e;
      }

      .logo-bar {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 6px;
      }

      .logo-dot {
        width: 6px;
        height: 6px;
        background-color: #c9a84c;
        border-radius: 50%;
        display: inline-block;
      }

      .wordmark {
        font-size: 22px;
        font-weight: 600;
        color: #c9a84c;
        letter-spacing: 4px;
        text-transform: uppercase;
        margin: 0;
      }

      .tagline {
        font-size: 11px;
        font-weight: 400;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #5a5040;
        margin: 10px 0 16px 0;
      }

      .subject-badge {
        display: inline-block;
        background-color: rgba(201, 168, 76, 0.1);
        border: 1px solid rgba(201, 168, 76, 0.25);
        padding: 5px 16px;
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #c9a84c;
      }

      /* ── Gold divider ── */
      .gold-divider {
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          #c9a84c40,
          transparent
        );
        margin: 0;
      }

      /* ── Content ── */
      .content {
        padding: 40px 40px;
      }

      .eyebrow {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #c9a84c;
        margin: 0 0 8px 0;
      }

      .headline {
        font-size: 26px;
        font-weight: 600;
        color: #f0ead8;
        line-height: 1.25;
        margin: 0 0 32px 0;
      }

      /* ── Fields ── */
      .field-block {
        margin-bottom: 22px;
        border-bottom: 1px solid #1e1e1e;
        padding-bottom: 18px;
      }

      .field-block:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .field-label {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #5a5040;
        margin: 0 0 6px 0;
      }

      .field-value {
        font-size: 14px;
        font-weight: 400;
        color: #e8e0d0;
        line-height: 1.6;
        margin: 0;
      }

      .field-value a {
        color: #c9a84c;
        text-decoration: none;
      }

      /* ── Message box ── */
      .message-box {
        background-color: #0d0d0d;
        border-left: 2px solid #c9a84c;
        padding: 18px 20px;
        margin-top: 8px;
      }

      .message-box p {
        font-size: 14px;
        font-weight: 400;
        color: #8a8070;
        line-height: 1.8;
        margin: 0;
        white-space: pre-wrap;
      }

      /* ── Meta row ── */
      .meta-row {
        display: table;
        width: 100%;
        margin-top: 32px;
        border-top: 1px solid #1e1e1e;
        padding-top: 22px;
      }

      .meta-cell {
        display: table-cell;
        width: 50%;
        vertical-align: top;
        padding-right: 16px;
      }

      /* ── Footer ── */
      .footer {
        background-color: #0d0d0d;
        border-top: 1px solid #1e1e1e;
        padding: 24px 40px;
        text-align: center;
        margin-top: 36px;
      }

      .footer-wordmark {
        font-size: 13px;
        font-weight: 600;
        color: #c9a84c;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin: 0 0 8px 0;
      }

      .footer-copy {
        font-size: 11px;
        font-weight: 300;
        color: #2a2a2a;
        margin: 0;
        line-height: 1.6;
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="container">
        <div class="header">
          <div class="logo-bar">
            <span class="logo-dot"></span>
            <p class="wordmark">Zaydoun</p>
            <span class="logo-dot"></span>
          </div>
          <p class="tagline">New support message</p>
          <span class="subject-badge"><%= SUBJECT %></span>
        </div>

        <div class="gold-divider"></div>

        <div class="content">
          <p class="eyebrow">Incoming message</p>
          <h1 class="headline"><%= SENDER_NAME %> wrote to you</h1>

          <div class="field-block">
            <p class="field-label">Email</p>
            <p class="field-value">
              <a href="mailto:<%= SENDER_EMAIL %>"><%= SENDER_EMAIL %></a>
            </p>
          </div>

          <div class="field-block">
            <p class="field-label">Subject</p>
            <p class="field-value"><%= SUBJECT %></p>
          </div>

          <div class="field-block">
            <p class="field-label">Message</p>
            <div class="message-box">
              <p><%= MESSAGE %></p>
            </div>
          </div>

          <div class="meta-row">
            <div class="meta-cell">
              <p class="field-label">Received</p>
              <p class="field-value" style="font-size: 12px; color: #5a5040">
                <%= RECEIVED_AT %> UTC
              </p>
            </div>
          </div>
        </div>

        <div class="footer">
          <p class="footer-wordmark">Zaydoun</p>
          <p class="footer-copy">
            Internal notification — Zaydoun &copy; <%= YEAR %>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
