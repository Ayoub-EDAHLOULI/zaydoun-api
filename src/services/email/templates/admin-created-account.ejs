<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your Zaydoun account is ready</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap");

      body {
        margin: 0;
        padding: 0;
        background-color: #0a0a0a;
        color: #e8e0d0;
        font-family: "Inter", "Segoe UI", sans-serif;
        font-weight: 400;
        -webkit-font-smoothing: antialiased;
      }

      .wrapper {
        padding: 40px 20px;
        background-color: #0a0a0a;
      }

      .container {
        max-width: 560px;
        margin: 0 auto;
        background-color: #111111;
        border: 1px solid #2a2a2a;
        overflow: hidden;
      }

      /* ── Header ── */
      .header {
        background-color: #0d0d0d;
        padding: 44px 40px 36px;
        text-align: center;
        border-bottom: 1px solid #1e1e1e;
      }

      .logo-bar {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 6px;
      }

      .logo-dot {
        width: 6px;
        height: 6px;
        background-color: #c9a84c;
        border-radius: 50%;
        display: inline-block;
      }

      .wordmark {
        font-size: 22px;
        font-weight: 600;
        color: #c9a84c;
        letter-spacing: 4px;
        text-transform: uppercase;
        margin: 0;
      }

      .tagline {
        font-size: 11px;
        font-weight: 400;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #5a5040;
        margin: 10px 0 0 0;
      }

      /* ── Gold divider ── */
      .gold-divider {
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          #c9a84c40,
          transparent
        );
        margin: 0;
      }

      /* ── Content ── */
      .content {
        padding: 44px 40px;
      }

      .eyebrow {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #c9a84c;
        margin: 0 0 18px 0;
      }

      .headline {
        font-size: 28px;
        font-weight: 600;
        color: #f0ead8;
        line-height: 1.25;
        margin: 0 0 16px 0;
      }

      .body-text {
        font-size: 14px;
        font-weight: 400;
        line-height: 1.75;
        color: #8a8070;
        margin: 0 0 28px 0;
      }

      /* ── Credentials box ── */
      .credentials {
        background-color: #0d0d0d;
        border: 1px solid #2a2a2a;
        border-left: 3px solid #c9a84c;
        padding: 20px 24px;
        margin: 0 0 28px 0;
      }

      .credential-row {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 12px;
      }

      .credential-row:last-child {
        margin-bottom: 0;
      }

      .cred-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #5a5040;
        min-width: 68px;
        flex-shrink: 0;
      }

      .cred-value {
        font-size: 13px;
        font-weight: 500;
        color: #e8e0d0;
        word-break: break-all;
      }

      .cred-value.password {
        font-family: "Courier New", Courier, monospace;
        font-size: 15px;
        color: #c9a84c;
        letter-spacing: 1px;
      }

      /* ── Notice ── */
      .notice-box {
        border-left: 2px solid #3a3028;
        padding: 13px 16px;
        background-color: #0d0d0d;
        margin: 0 0 32px 0;
      }

      .notice-box p {
        font-size: 12px;
        font-weight: 400;
        line-height: 1.7;
        color: #5a5040;
        margin: 0;
      }

      /* ── CTA ── */
      .cta-wrap {
        text-align: center;
        margin: 0 0 8px 0;
      }

      .cta-button {
        display: inline-block;
        padding: 14px 40px;
        background-color: #c9a84c;
        color: #0d0d0d !important;
        text-decoration: none;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
      }

      /* ── Footer ── */
      .footer {
        background-color: #0d0d0d;
        border-top: 1px solid #1e1e1e;
        padding: 28px 40px;
        text-align: center;
        margin-top: 44px;
      }

      .footer-wordmark {
        font-size: 13px;
        font-weight: 600;
        color: #c9a84c;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin: 0 0 12px 0;
      }

      .footer-links {
        margin: 0 0 12px 0;
      }

      .footer-links a {
        font-size: 10px;
        font-weight: 400;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #3a3028;
        text-decoration: none;
        margin: 0 10px;
      }

      .footer-copy {
        font-size: 11px;
        font-weight: 300;
        color: #2a2a2a;
        margin: 0;
        line-height: 1.6;
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="container">
        <div class="header">
          <div class="logo-bar">
            <span class="logo-dot"></span>
            <p class="wordmark">Zaydoun</p>
            <span class="logo-dot"></span>
          </div>
          <p class="tagline">Your AI reading companion</p>
        </div>

        <div class="gold-divider"></div>

        <div class="content">
          <p class="eyebrow">Account created</p>

          <h1 class="headline">
            Welcome, <%= NAME %>.<br />
            Your account is ready.
          </h1>

          <p class="body-text">
            An administrator has created a Zaydoun account for you. Use the
            credentials below to sign in, then change your password from your
            profile settings.
          </p>

          <div class="credentials">
            <div class="credential-row">
              <span class="cred-label">Email</span>
              <span class="cred-value"><%= EMAIL %></span>
            </div>
            <div class="credential-row">
              <span class="cred-label">Password</span>
              <span class="cred-value password"><%= TEMP_PASSWORD %></span>
            </div>
          </div>

          <div class="notice-box">
            <p>
              This is a temporary password. For your security, please change it
              immediately after your first login via
              <strong style="color: #e8e0d0">Profile → Change password</strong>.
            </p>
          </div>

          <div class="cta-wrap">
            <a href="<%= APP_URL %>/login" class="cta-button"
              >Sign in to Zaydoun</a
            >
          </div>
        </div>

        <div class="footer">
          <p class="footer-wordmark">Zaydoun</p>
          <div class="footer-links">
            <a href="<%= APP_URL %>">App</a>
            <a href="<%= APP_URL %>/privacy">Privacy</a>
            <a href="<%= APP_URL %>/terms">Terms</a>
          </div>
          <p class="footer-copy">
            &copy; <%= YEAR %> Zaydoun. All rights reserved.<br />
            You received this email because an admin created an account for you.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
