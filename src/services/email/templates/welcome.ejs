<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Zaydoun</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap");

      body {
        margin: 0;
        padding: 0;
        background-color: #0a0a0a;
        color: #e8e0d0;
        font-family: "Inter", "Segoe UI", sans-serif;
        font-weight: 400;
        -webkit-font-smoothing: antialiased;
      }

      .wrapper {
        padding: 40px 20px;
        background-color: #0a0a0a;
      }

      .container {
        max-width: 560px;
        margin: 0 auto;
        background-color: #111111;
        border: 1px solid #2a2a2a;
        overflow: hidden;
      }

      /* ── Header ── */
      .header {
        background-color: #0d0d0d;
        padding: 44px 40px 36px;
        text-align: center;
        border-bottom: 1px solid #1e1e1e;
      }

      .logo-bar {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 6px;
      }

      .logo-dot {
        width: 6px;
        height: 6px;
        background-color: #c9a84c;
        border-radius: 50%;
        display: inline-block;
      }

      .wordmark {
        font-size: 22px;
        font-weight: 600;
        color: #c9a84c;
        letter-spacing: 4px;
        text-transform: uppercase;
        margin: 0;
      }

      .tagline {
        font-size: 11px;
        font-weight: 400;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #5a5040;
        margin: 10px 0 0 0;
      }

      /* ── Gold divider ── */
      .gold-divider {
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          #c9a84c40,
          transparent
        );
        margin: 0;
      }

      /* ── Content ── */
      .content {
        padding: 44px 40px;
      }

      .eyebrow {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #c9a84c;
        margin: 0 0 18px 0;
      }

      .headline {
        font-size: 28px;
        font-weight: 600;
        color: #f0ead8;
        line-height: 1.25;
        margin: 0 0 20px 0;
      }

      .body-text {
        font-size: 14px;
        font-weight: 400;
        line-height: 1.75;
        color: #8a8070;
        margin: 0 0 36px 0;
      }

      /* ── CTA ── */
      .cta-wrap {
        text-align: center;
        margin: 0 0 44px 0;
      }

      .cta-button {
        display: inline-block;
        padding: 14px 40px;
        background-color: #c9a84c;
        color: #0d0d0d !important;
        text-decoration: none;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
      }

      /* ── Feature pills ── */
      .features {
        border-top: 1px solid #1e1e1e;
        padding-top: 32px;
        display: table;
        width: 100%;
      }

      .feature-item {
        display: table-cell;
        text-align: center;
        padding: 0 8px;
        vertical-align: top;
      }

      .feature-bar {
        display: block;
        width: 24px;
        height: 2px;
        background-color: #c9a84c;
        margin: 0 auto 12px;
        opacity: 0.6;
      }

      .feature-title {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #e8e0d0;
        display: block;
        margin: 0 0 5px 0;
      }

      .feature-desc {
        font-size: 11px;
        font-weight: 400;
        color: #5a5040;
        display: block;
        line-height: 1.5;
      }

      /* ── Footer ── */
      .footer {
        background-color: #0d0d0d;
        border-top: 1px solid #1e1e1e;
        padding: 28px 40px;
        text-align: center;
        margin-top: 44px;
      }

      .footer-wordmark {
        font-size: 13px;
        font-weight: 600;
        color: #c9a84c;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin: 0 0 12px 0;
      }

      .footer-links {
        margin: 0 0 12px 0;
      }

      .footer-links a {
        font-size: 10px;
        font-weight: 400;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #3a3028;
        text-decoration: none;
        margin: 0 10px;
      }

      .footer-copy {
        font-size: 11px;
        font-weight: 300;
        color: #2a2a2a;
        margin: 0;
        line-height: 1.6;
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="container">
        <div class="header">
          <div class="logo-bar">
            <span class="logo-dot"></span>
            <p class="wordmark">Zaydoun</p>
            <span class="logo-dot"></span>
          </div>
          <p class="tagline">Your AI reading companion</p>
        </div>

        <div class="gold-divider"></div>

        <div class="content">
          <p class="eyebrow">New account</p>

          <h1 class="headline">
            Welcome, <%= NAME %>.<br />
            Your library awaits.
          </h1>

          <p class="body-text">
            Your Zaydoun account is ready. Upload any book, and Zaydoun will
            become your personal guide through it — answering questions,
            surfacing key ideas, and helping you go deeper than you ever could
            alone.
          </p>

          <div class="cta-wrap">
            <a href="<%= APP_URL %>" class="cta-button">Open your library</a>
          </div>

          <div class="features">
            <div class="feature-item">
              <span class="feature-bar"></span>
              <span class="feature-title">Upload</span>
              <span class="feature-desc">Any PDF,<br />any language</span>
            </div>
            <div class="feature-item">
              <span class="feature-bar"></span>
              <span class="feature-title">Ask</span>
              <span class="feature-desc">Voice or text,<br />real answers</span>
            </div>
            <div class="feature-item">
              <span class="feature-bar"></span>
              <span class="feature-title">Explore</span>
              <span class="feature-desc">Deep context,<br />every time</span>
            </div>
          </div>
        </div>

        <div class="footer">
          <p class="footer-wordmark">Zaydoun</p>
          <div class="footer-links">
            <a href="<%= APP_URL %>">App</a>
            <a href="<%= APP_URL %>/privacy">Privacy</a>
            <a href="<%= APP_URL %>/terms">Terms</a>
          </div>
          <p class="footer-copy">
            &copy; <%= YEAR %> Zaydoun. All rights reserved.<br />
            You received this email because you just created an account.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
